{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hermes-buildathon-agency",
  "compatibility_date": "2026-07-12",
  "workers_dev": true,
  "preview_urls": true,
  "assets": {
    "directory": "./dist/client",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
